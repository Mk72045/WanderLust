<% layout("/layouts/boiler") %>

<div class="filterscontainer">
  <div class="d-flex flex-nowrap overflow-auto gap-3 mt-3">
    <div class="filter mt-3">
      <i class="fa-solid fa-fire"></i>
      <p>Trendings</p>
    </div>
    <div class="filter mt-3">
      <i class="fa-solid fa-bed"></i>
      <p>Rooms</p>
    </div>
    <div class="filter mt-3">
      <i class="fa-solid fa-mountain-city"></i>
      <p>Iconic City</p>
    </div>
    <div class="filter mt-3">
      <i class="fa-solid fa-mountain"></i>
      <p>Mountain</p>
    </div>
    <div class="filter mt-3">
      <i class="fa-solid fa-person-swimming"></i>
      <p>Swimming Pool</p>
    </div>
    <div class="filter mt-3">
      <i class="fa-solid fa-campground"></i>
      <p>Camping</p>
    </div>
    <div class="filter mt-3">
      <i class="fa-solid fa-cow"></i>
      <p>Farms</p>
    </div>
    <div class="filter mt-3">
      <i class="fa-solid fa-snowflake"></i>
      <p>Arctic</p>
    </div>
    <div class="filter mt-3">
      <i class="fa-solid fa-igloo"></i>
      <p>Doms</p>
    </div>
    <div class="filter mt-3">
      <i class="fa-solid fa-ship"></i>
      <p>Boats</p>
    </div>
  </div>
</div>

<div class="row-cols-xxl-4 row row-cols-xl-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <% for(let list of listings) { %>
  <a href="/listings/<%= list.id %>" class="listing-link">
    <div class="card col listing-card" style="width: 20rem">
      <img
        src="<%= list.image.url %>"
        class="card-img-top"
        alt="listing_image"
        style="height: 20rem"
      />
      <div class="card-img-overlay">
        <p></p>
      </div>

      <div class="card-body">
        <p class="card-text">
          <b><%= list.title %></b> <br />
          &#8377;
          <%= list.price.toLocaleString("en-IN") %>
        </p>
      </div>
    </div>
  </a>
  <% } %>
</div>
